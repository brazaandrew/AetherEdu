# Protect uploads directory
# Allow only specific file types to be accessed

<FilesMatch "\.(php|php3|php4|php5|phtml|pl|py|jsp|asp|sh|cgi)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Allow access to common file types
<FilesMatch "\.(jpg|jpeg|png|gif|pdf|doc|docx|xls|xlsx|ppt|pptx|txt|zip)$">
    Order allow,deny
    Allow from all
</FilesMatch>

Options -Indexes
