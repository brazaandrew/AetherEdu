{
  "builds": [
    { "src": "public/**/*.php", "use": "vercel-php@0.9.0" },
    { "src": "api/**/*.php", "use": "vercel-php@0.9.0" },
    { "src": "*.php", "use": "vercel-php@0.9.0" }
  ],
  "routes": [
    { "src": "/(.*\\.php)", "dest": "/public/$1" },
    { "src": "/(.*)", "dest": "/public/index.php" }
  ]
}
